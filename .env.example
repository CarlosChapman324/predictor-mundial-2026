# Claves de API para la Capa 2 y el modulo de valor. Copia este archivo a .env
# (que esta en .gitignore) y rellena tus claves. NUNCA commitees el .env.
# En el deploy/cron, estas claves van en los secrets de GitHub Actions.

# The Odds API (cuotas 1X2 y totales) - https://the-odds-api.com
THE_ODDS_API_KEY=

# API-Football via RapidAPI (stats por partido, arbitros) - https://rapidapi.com/api-sports/api/api-football
RAPIDAPI_KEY=
